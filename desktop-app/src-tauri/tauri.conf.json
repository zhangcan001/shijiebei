{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WorldCupOddsPro",
  "version": "0.1.0",
  "identifier": "com.local.worldcupoddspro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "世界杯盈利模型工作台",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
